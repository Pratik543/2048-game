pipeline {
    agent any  // Pipeline Script to Deploy 2048 Game on EC2 Instance without parameters

    environment {
        AWS_REGION     = 'ap-south-1'
        INSTANCE_USER  = 'ubuntu'
        TERRAFORM_DIR  = "${WORKSPACE}/terraform-setup"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Pratik543/2048-game.git'
            }
        }

        stage('Terraform Init & Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'EC2_KEY_NAME',          variable: 'EC2_KEY_NAME')
                ]) {
                    dir(TERRAFORM_DIR) {
                        writeFile file: 'terraform.tfvars', text: """\
                            region   = "${AWS_REGION}"
                            key_name = "${EC2_KEY_NAME}"
                        """.stripIndent()

                        sh '''
                            export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
                            export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"
                            terraform init -input=false
                            terraform apply -auto-approve -input=false
                        '''
                    }
                }
            }
        }

        stage('Get EC2 Public IP') {
            steps {
                dir(TERRAFORM_DIR) {
                    script {
                        env.INSTANCE_IP = sh(
                            script: 'terraform output -raw instance_public_ip',
                            returnStdout: true
                        ).trim()
                    }
                }
                echo "EC2 Instance IP: ${env.INSTANCE_IP}"
            }
        }

        stage('Setup Docker on EC2') {
            steps {
                withCredentials([file(credentialsId: 'EC2_SSH_KEY', variable: 'KEY_PATH')]) {
                    sh '''
                        chmod 400 "$KEY_PATH"

                        SSH_OPTS="-o StrictHostKeyChecking=no \
                                  -o ConnectTimeout=5 \
                                  -o ServerAliveInterval=15 \
                                  -o BatchMode=yes"

                        # ── Wait for SSH to be ready ──
                        echo "Waiting for SSH on ${INSTANCE_IP}..."
                        for i in $(seq 1 30); do
                            if ssh $SSH_OPTS -i "$KEY_PATH" \
                                 "${INSTANCE_USER}@${INSTANCE_IP}" \
                                 "exit 0" 2>/dev/null; then
                                echo "SSH ready after attempt $i"
                                break
                            fi
                            if [ "$i" -eq 30 ]; then
                                echo "SSH timeout after 30 attempts"
                                exit 1
                            fi
                            sleep 10
                        done

                        # ── Install Docker on EC2 ──
                        ssh $SSH_OPTS -i "$KEY_PATH" \
                            "${INSTANCE_USER}@${INSTANCE_IP}" bash -s <<'REMOTE'
                            set -ex
                            export DEBIAN_FRONTEND=noninteractive

                            # ── Wait for APT locks ──
                            wait_for_apt() {
                                echo "Waiting for apt locks..."
                                while sudo fuser /var/lib/dpkg/lock-frontend \
                                                 /var/lib/apt/lists/lock \
                                                 /var/cache/apt/archives/lock \
                                                 /var/lib/dpkg/lock >/dev/null 2>&1; do
                                    echo "  apt is locked — retrying in 5s..."
                                    sleep 5
                                done
                                echo "apt is free."
                            }

                            # ── Wait for network/DNS ──
                            echo "Waiting for network..."
                            for i in $(seq 1 12); do
                                if curl -fsSL --connect-timeout 5 \
                                     https://get.docker.com/ -o /dev/null 2>/dev/null; then
                                    echo "Network ready."
                                    break
                                fi
                                [ "$i" -eq 12 ] && { echo "Network timeout"; exit 1; }
                                sleep 10
                            done

                            # ── Install Docker ──
                            wait_for_apt
                            sudo apt-get update -y
                            sudo apt-get install -y curl

                            wait_for_apt
                            curl -fsSL https://get.docker.com -o /tmp/get-docker.sh
                            sudo sh /tmp/get-docker.sh
                            rm -f /tmp/get-docker.sh

                            sudo systemctl enable --now docker
                            sudo usermod -aG docker "$(whoami)"

                            # ── Verify Docker ──
                            for i in $(seq 1 6); do
                                if sudo docker info >/dev/null 2>&1; then
                                    echo "Docker installed: $(sudo docker --version)"
                                    exit 0
                                fi
                                sleep 5
                            done
                            echo "Docker failed to start"
                            exit 1
REMOTE
                    '''
                }
            }
        }

        stage('Deploy 2048 Game') {
            steps {
                withCredentials([file(credentialsId: 'EC2_SSH_KEY', variable: 'KEY_PATH')]) {
                    sh '''
                        chmod 400 "$KEY_PATH"

                        SSH_OPTS="-o StrictHostKeyChecking=no \
                                  -o ConnectTimeout=5 \
                                  -o BatchMode=yes"

                        # ── Copy Dockerfile from cloned repo ──
                        scp $SSH_OPTS -i "$KEY_PATH" \
                            "${WORKSPACE}/Dockerfile" \
                            "${INSTANCE_USER}@${INSTANCE_IP}:/home/${INSTANCE_USER}/Dockerfile"

                        # ── Build & Run on EC2 ──
                        ssh $SSH_OPTS -i "$KEY_PATH" \
                            "${INSTANCE_USER}@${INSTANCE_IP}" bash -s <<'REMOTE'
                            set -ex
                            cd /home/ubuntu
                            sudo docker build -t 2048-game .
                            sudo docker rm -f 2048-game 2>/dev/null || true
                            sudo docker run -d \
                                --name 2048-game \
                                --restart unless-stopped \
                                -p 80:80 \
                                2048-game
REMOTE
                    '''
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    echo "Verifying http://${INSTANCE_IP} ..."
                    for i in $(seq 1 12); do
                        HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
                                    "http://${INSTANCE_IP}" || true)
                        if [ "$HTTP_CODE" = "200" ]; then
                            echo "✅ Game is live at http://${INSTANCE_IP}"
                            exit 0
                        fi
                        sleep 5
                    done
                    echo "❌ Deployment verification failed"
                    exit 1
                '''
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed — check logs above."
        }
        success {
            echo "✅ 2048 Game deployed at http://${env.INSTANCE_IP}"
        }
    }
}